{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "playwright": {
        "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest"],
    "enabled": true      
    }
  },
  "permission": {
    "*": "ask",
    "bash": "allow",
    "read": "allow",
    "edit": "allow",
    "Glob **/*.py": "allow",
    "**/*.md": "ask",
    "Call tool todowrite": "allow",
    "playwright_browser_navigate": "allow",
    "playwright_browser_click": "allow",
    "playwright_browser_evaluate": "allow"
  }  
}